#!/usr/bin/env bash

ROFI_CMD="rofi -dmenu -i -p Emoji -theme ~/.config/rofi/scripts/rofi-popup.rasi"

EMOJIS=(
    "😀" "😃" "😄" "😁" "😅" "😂" "🤣" "😊"
    "😇" "🙂" "😉" "😌" "😍" "🥰" "😘" "😗"
    "😋" "😛" "😜" "🤪" "😝" "🤑" "🤗" "🤭"
    "🤔" "🤐" "😐" "😑" "😶" "😏" "😒" "🙄"
    "😬" "🤥" "😌" "😔" "😪" "🤤" "😴" "😷"
    "🤒" "🤕" "🤢" "🤮" "🥴" "😵" "🤯" "🤠"
    "🥳" "😎" "🤓" "🧐" "😕" "😟" "🙁" "☹️"
    "😮" "😯" "😲" "😳" "🥺" "😦" "😧" "😨"
    "😰" "😥" "😢" "😭" "😱" "😖" "😣" "😞"
    "👍" "👎" "👌" "✌️" "🤞" "🤟" "🤘" "🤙"
    "👋" "🤚" "🖐️" "✋" "🖖" "👏" "🙌" "🤲"
    "❤️" "🧡" "💛" "💚" "💙" "💜" "🖤" "🤍"
    "💯" "🔥" "⭐" "🌟" "✨" "💡" "🔑" "🗝️"
    "🎉" "🎊" "🎈" "🎁" "🏆" "🥇" "🥈" "🥉"
    "🚀" "✈️" "🌍" "🌎" "🌏" "🌈" "☀️" "🌙"
)

choice=$(printf "%s\n" "${EMOJIS[@]}" | $ROFI_CMD)

if [ -n "$choice" ]; then
    echo "$choice" | xclip -selection clipboard
    notify-send "Emoji" "Copied: $choice"
fi
